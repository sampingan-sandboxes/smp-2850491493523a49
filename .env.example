# Cognito hosted-UI domain (no protocol), e.g. my-pool.auth.ap-southeast-1.amazoncognito.com
VITE_COGNITO_DOMAIN=
# Cognito App Client id (public SPA client, no secret).
VITE_COGNITO_CLIENT_ID=
# Base URL of the backend API (used by the playbook run clients).
VITE_BACKEND_URL=
# Set to "true" (dev only) to start the msw browser worker so the app runs without a backend.
VITE_ENABLE_MOCKS=
